# Copy this file to .env and fill in your values
# Never commit .env to git

# Visual Crossing — actual temperature at resolution (required for calibration)
# Free tier at https://www.visualcrossing.com/weather-api
VC_KEY=your_visual_crossing_key_here

# Polygon wallet private key — required for live trading only
# Create a burner wallet: https://metamask.io
# Fund with USDC on Polygon L2
POLYGON_PRIVATE_KEY=0x_your_private_key_here

# Anthropic API key — required for AI-assisted trade decisions (optional)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Paper trading mode (true = no real trades, false = live)
PAPER_TRADING=true
