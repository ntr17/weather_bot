# Copy this file to .env and fill in YOUR values.
# NEVER commit .env to git or include it in bundles/emails.
# ============================================================

# ---- Polymarket / Trading ----

# Visual Crossing -- actual temperature at resolution (required for calibration)
# Free tier: https://www.visualcrossing.com/weather-api
VC_KEY=your_visual_crossing_key_here

# Polygon wallet private key -- required for live trading only
# Create a burner wallet: https://metamask.io then fund with USDC on Polygon L2
POLYGON_PRIVATE_KEY=0x_your_private_key_here

# Anthropic API key -- required for AI-assisted trade decisions (optional)
ANTHROPIC_API_KEY=sk-ant-your_key_here

# Paper trading mode (true = no real trades, false = live)
# Keep true until you have tested extensively in paper mode!
PAPER_TRADING=true

# ---- Code Transfer: Work machine (scripts/ship_to_personal.ps1) ----
# The Gmail address where bundles are sent TO
PERSONAL_EMAIL=your.personal@gmail.com

# ---- Code Transfer: Personal machine (scripts/ship_data_back.py) ----
# Gmail address used to SEND data back from personal machine
GMAIL_ADDRESS=your.personal@gmail.com
# Gmail App Password (NOT your regular password -- see WORKFLOW.md > Gmail Setup)
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Work Outlook address where data is sent back to
WORK_EMAIL=your.name@work-company.com